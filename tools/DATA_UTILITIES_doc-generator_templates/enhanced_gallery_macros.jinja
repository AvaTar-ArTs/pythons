{# Macro to render gallery images by string range with enhanced features #}
{% macro enhanced_gallery_images_string(from, to, images) -%}
  <div class="enhanced-gallery">
    {% set index = namespace(value=0) %}
    {% set first_photo = namespace(value=-1) %}
    {% for image in images %}
      {% if image.name >= from and image.name <= to %}
        {% if first_photo.value == -1 %}
          {% set first_photo.value = loop.index %}
        {% endif %}
        <div class="gallery-item" 
             data-type="{{ image.type }}"
             data-date="{{ image.date }}"
             data-quality="{{ image.content_analysis.aesthetic_score.overall_aesthetic_score if image.content_analysis else 0 }}"
             data-faces="{{ image.content_analysis.face_analysis.faces_detected if image.content_analysis else false }}"
             data-tags="{{ image.content_analysis.scene_classification.scene_category if image.content_analysis else '' }}"
             data-description="{{ image.description }}"
             data-src="{{ image.src }}"
             data-width="{{ image.size[0] }}"
             data-height="{{ image.size[1] }}"
             data-thumbnail="{{ image.thumbnail }}"
             data-thumbnail-width="{{ image.thumbnail_size[0] }}"
             data-thumbnail-height="{{ image.thumbnail_size[1] }}"
             data-index="{{ index.value }}"
             data-gallery="{{ first_photo.value }}">
          
          <img src="{{ image.thumbnail }}" alt="{{ image.description }}" loading="lazy">
          
          {# Quality Badge #}
          {% if image.content_analysis and image.content_analysis.aesthetic_score %}
            {% set quality_grade = image.content_analysis.aesthetic_score.aesthetic_grade %}
            <div class="quality-badge">{{ quality_grade }}</div>
          {% endif %}
          
          {# Overlay with enhanced information #}
          <div class="item-overlay">
            <div class="item-title">
              {% if image.description %}
                {{ image.description[:50] }}{% if image.description|length > 50 %}...{% endif %}
              {% else %}
                {{ image.name|replace('_', ' ')|title }}
              {% endif %}
            </div>
            
            <div class="item-meta">
              <span><i class="fas fa-calendar"></i> {{ image.date.strftime('%Y-%m-%d') if image.date else 'Unknown' }}</span>
              <span><i class="fas fa-expand-arrows-alt"></i> {{ image.size[0] }}×{{ image.size[1] }}</span>
              {% if image.content_analysis and image.content_analysis.face_analysis.faces_detected %}
                <span><i class="fas fa-user"></i> {{ image.content_analysis.face_analysis.face_count }} face(s)</span>
              {% endif %}
            </div>
            
            {# Tags based on content analysis #}
            {% if image.content_analysis %}
              <div class="item-tags">
                {% if image.content_analysis.scene_classification.scene_category %}
                  <span class="tag">{{ image.content_analysis.scene_classification.scene_category|title }}</span>
                {% endif %}
                {% if image.content_analysis.scene_classification.indoor_outdoor %}
                  <span class="tag">{{ image.content_analysis.scene_classification.indoor_outdoor|title }}</span>
                {% endif %}
                {% if image.content_analysis.scene_classification.time_of_day %}
                  <span class="tag">{{ image.content_analysis.scene_classification.time_of_day|title }}</span>
                {% endif %}
                {% if image.content_analysis.face_analysis.faces_detected %}
                  <span class="tag">People</span>
                {% endif %}
                {% if image.content_analysis.text_content.has_text %}
                  <span class="tag">Text</span>
                {% endif %}
              </div>
            {% endif %}
          </div>
        </div>
        {% set index.value = index.value + 1 %}
      {% endif %}
    {% endfor %}
  </div>
{%- endmacro %}

{# Macro to render a gallery section with enhanced features #}
{% macro enhanced_section(from, to, title, description, images) -%}
  <div class="container-fluid">
    <div class="row">
      <div class="col gallery-section">
        <h2>{{ title }}</h2>
        <p>{{ description }}</p>
      </div>
    </div>
    {% if from is number %}
      {{ enhanced_gallery_images_index(from, to, images) }}
    {% else %}
      {{ enhanced_gallery_images_string(from, to, images) }}
    {% endif %}
  </div>
{%- endmacro %}

{# Macro to render content analysis summary #}
{% macro content_analysis_summary(images) -%}
  <div class="content-analysis">
    <h3 class="analysis-title">
      <i class="fas fa-chart-bar"></i>
      Content Analysis Summary
    </h3>
    
    <div class="row">
      <div class="col-md-4">
        <div class="analysis-section">
          <h5 class="analysis-title">
            <i class="fas fa-palette"></i>
            Color Analysis
          </h5>
          <div class="analysis-content">
            {% set all_colors = [] %}
            {% for image in images %}
              {% if image.content_analysis and image.content_analysis.color_analysis %}
                {% for color in image.content_analysis.color_analysis.dominant_colors[:3] %}
                  {% set _ = all_colors.append(color) %}
                {% endfor %}
              {% endif %}
            {% endfor %}
            
            {% if all_colors %}
              <p>Most common colors across all images:</p>
              <div class="color-palette">
                {% for color in all_colors[:5] %}
                  <div class="color-swatch" style="background-color: {{ color.hex }};" title="{{ color.hex }} ({{ color.percentage }}%)"></div>
                {% endfor %}
              </div>
            {% else %}
              <p>No color analysis available</p>
            {% endif %}
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="analysis-section">
          <h5 class="analysis-title">
            <i class="fas fa-user"></i>
            Face Detection
          </h5>
          <div class="analysis-content">
            {% set face_count = images|selectattr('content_analysis.face_analysis.faces_detected', 'equalto', true)|list|length %}
            {% set total_faces = images|sum(attribute='content_analysis.face_analysis.face_count') if images[0].content_analysis else 0 %}
            <p><strong>{{ face_count }}</strong> images contain faces</p>
            <p><strong>{{ total_faces }}</strong> total faces detected</p>
            <p>{{ "%.1f"|format((face_count / images|length * 100) if images|length > 0 else 0) }}% of images have faces</p>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="analysis-section">
          <h5 class="analysis-title">
            <i class="fas fa-star"></i>
            Quality Distribution
          </h5>
          <div class="analysis-content">
            {% set quality_grades = {'A': 0, 'B': 0, 'C': 0, 'D': 0} %}
            {% for image in images %}
              {% if image.content_analysis and image.content_analysis.aesthetic_score %}
                {% set grade = image.content_analysis.aesthetic_score.aesthetic_grade %}
                {% if grade in quality_grades %}
                  {% set _ = quality_grades.update({grade: quality_grades[grade] + 1}) %}
                {% endif %}
              {% endif %}
            {% endfor %}
            
            {% for grade, count in quality_grades.items() %}
              <p><strong>{{ grade }}:</strong> {{ count }} images ({{ "%.1f"|format((count / images|length * 100) if images|length > 0 else 0) }}%)</p>
            {% endfor %}
          </div>
        </div>
      </div>
    </div>
  </div>
{%- endmacro %}