    {% for i in range(from, to) %}
      <div class="gallery-item" 
           data-type="{{ images[i].type }}"
           data-date="{{ images[i].date }}"
           data-quality="{{ images[i].content_analysis.aesthetic_score.overall_aesthetic_score if images[i].content_analysis else 0 }}"
           data-faces="{{ images[i].content_analysis.face_analysis.faces_detected if images[i].content_analysis else false }}"
           data-tags="{{ images[i].content_analysis.scene_classification.scene_category if images[i].content_analysis else '' }}"
           data-description="{{ images[i].description }}"
           data-src="{{ images[i].src }}"
           data-width="{{ images[i].size[0] }}"
           data-height="{{ images[i].size[1] }}"
           data-thumbnail="{{ images[i].thumbnail }}"
           data-thumbnail-width="{{ images[i].thumbnail_size[0] }}"
           data-thumbnail-height="{{ images[i].thumbnail_size[1] }}"
           data-index="{{ i - from }}"
           data-gallery="{{ from }}">
        
        <img src="{{ images[i].thumbnail }}" alt="{{ images[i].description }}" loading="lazy">
        
        {# Quality Badge #}
        {% if images[i].content_analysis and images[i].content_analysis.aesthetic_score %}
