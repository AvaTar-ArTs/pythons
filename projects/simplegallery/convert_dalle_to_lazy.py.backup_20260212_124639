#!/usr/bin/env python3
"""
Convert dalle.html to 2.1 lazy-loading format with pagination
"""

import json
import re
from html.parser import HTMLParser
from collections import OrderedDict


class ImageExtractor(HTMLParser):
    def __init__(self):
        super().__init__()
        self.images = []
        self.current_href = None
        self.current_alt = None
        self.current_index = None
        self.in_gallery_photo = False

    def handle_starttag(self, tag, attrs):
        if tag == "a":
            for attr, value in attrs:
                if attr == "class" and "gallery-photo" in value:
                    self.in_gallery_photo = True
                elif attr == "href" and self.in_gallery_photo:
                    self.current_href = value
                elif attr == "data-index" and self.in_gallery_photo:
                    self.current_index = int(value)
        elif tag == "img" and self.in_gallery_photo:
            for attr, value in attrs:
                if attr == "alt":
                    self.current_alt = value

    def handle_endtag(self, tag):
        if tag == "a" and self.in_gallery_photo and self.current_href:
            self.images.append(
                {
                    "href": self.current_href,
                    "alt": self.current_alt or "",
                    "index": self.current_index or len(self.images),
                }
            )
            self.in_gallery_photo = False
            self.current_href = None
            self.current_alt = None
            self.current_index = None


def extract_images(html_file):
    """Extract images from dalle.html"""
    with open(html_file, "r", encoding="utf-8") as f:
        content = f.read()

    parser = ImageExtractor()
    parser.feed(content)

    # Sort by index
    parser.images.sort(key=lambda x: x.get("index", 0))

    return parser.images


def create_images_data(images):
    """Create images_data.json format"""
    images_data = OrderedDict()

    for idx, img in enumerate(images):
        img_src = img["href"]
        img_alt = img.get("alt", "")

        # Extract filename from URL
        filename_match = re.search(r"/([^/]+\.webp)", img_src)
        if filename_match:
            filename = filename_match.group(1)
        else:
            filename = f"dalle_image_{idx:04d}.webp"

        images_data[filename] = {
            "src": img_src,
            "mtime": 0,
            "date": "",
            "size": [1024, 1024],
            "type": "image",
            "description": img_alt[:500] if img_alt else "",
            "thumbnail": img_src,
            "thumbnail_size": [160, 160],
        }

    return images_data


def create_search_index(images_data):
    """Create search index for images"""
    search_index = {"all_names": [], "by_filename": {}, "by_description": {}}

    for filename, img_data in images_data.items():
        search_index["all_names"].append(filename)

        # Index by filename
        filename_lower = filename.lower()
        for word in re.findall(r"\w+", filename_lower):
            if len(word) > 2:
                if word not in search_index["by_filename"]:
                    search_index["by_filename"][word] = []
                if filename not in search_index["by_filename"][word]:
                    search_index["by_filename"][word].append(filename)

        # Index by description
        description = img_data.get("description", "").lower()
        for word in re.findall(r"\w+", description):
            if len(word) > 2:
                if word not in search_index["by_description"]:
                    search_index["by_description"][word] = []
                if filename not in search_index["by_description"][word]:
                    search_index["by_description"][word].append(filename)

    return search_index


def main():
    print("Converting dalle.html to lazy-loading format...")

    # Extract images
    images = extract_images("dalle.html")
    print(f"Extracted {len(images)} images")

    # Create images_data.json
    images_data = create_images_data(images)
    with open("dalle_images_data.json", "w", encoding="utf-8") as f:
        json.dump(images_data, f, indent=2, ensure_ascii=False)
    print(f"Created dalle_images_data.json with {len(images_data)} images")

    # Create search index
    search_index = create_search_index(images_data)
    with open("dalle_search_index.json", "w", encoding="utf-8") as f:
        json.dump(search_index, f, indent=2, ensure_ascii=False)
    print("Created dalle_search_index.json")

    print("\nSummary:")
    print(f"  Total images: {len(images_data)}")
    print(f"  Search keywords (filename): {len(search_index['by_filename'])}")
    print(f"  Search keywords (description): {len(search_index['by_description'])}")


if __name__ == "__main__":
    main()
